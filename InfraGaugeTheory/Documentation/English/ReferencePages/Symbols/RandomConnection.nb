Notebook[{
Cell["RandomConnection", "Title",ExpressionUUID->"35d49032-bc6b-41ef-b33d-c65c6a65ed90"],

Cell["\<\
RandomConnection[total, proj] generates a random connection on a fiber bundle.\
\>", "Text",ExpressionUUID->"26f03ac2-2df4-45b3-963f-b3eda22607fd"],

Cell["Details", "Section",ExpressionUUID->"42dfaf13-a2cd-4a56-a80c-4feb34112a99"],

Cell["\<\
A connection is a subgraph of the total space that provides horizontal lifts: \
for each fiber vertex and each neighboring base direction, exactly one \
horizontal edge.\
\>", "Text",ExpressionUUID->"847e0469-3d26-4352-9c61-e84271eeff54"],

Cell["\<\
RandomConnection uses independent edge set matching to select non-overlapping \
horizontal edges between fibers.\
\>", "Text",ExpressionUUID->"c59d8945-1769-4d8b-a10e-a8e166a8e90e"],

Cell["\<\
The result is a Graph on the same vertex set as total, with only the \
connection edges.\
\>", "Text",ExpressionUUID->"645bf9f2-0c56-493c-98c3-6b157a457358"],

Cell["Use ConnectionQ to verify the result is a valid connection.", "Text",ExpressionUUID->"b8d9cfac-a903-4e54-8db7-c6d3d5e10346"],

Cell["Use UniqueLiftQ to check the unique lifting property.", "Text",ExpressionUUID->"ee92f973-5bca-4829-8e19-75e0016c5d6b"],

Cell["Examples", "Section",ExpressionUUID->"874f7b55-8b23-488e-9d50-89a595ab45eb"],

Cell["Needs[\"WolframInstitute`InfraGaugeTheory`\"]", "Input",ExpressionUUID->"c454f2a4-6f2b-42ef-b396-38807f25a9de"],

Cell["Create a connection on a fibration:", "Text",ExpressionUUID->"bbf5f847-38a0-4fc5-bfd4-bbf3b092a81a"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
conn = RandomConnection[total, proj];
{GraphQ[conn], EdgeCount[conn]}\
\>", "Input",ExpressionUUID->"66d81811-0b36-4509-8ad5-c6169a9121ee"],

Cell["Verify it is a valid connection:", "Text",ExpressionUUID->"003176cb-ee1f-4847-bfbc-9eaf06e41994"],

Cell["ConnectionQ[total, proj, conn]", "Input",ExpressionUUID->"7ebf60f2-a10e-4b51-a73d-9910f6a34a5d"],

Cell["Check unique lifting:", "Text",ExpressionUUID->"e3a47041-9134-41c3-8918-1c3518c39804"],

Cell["UniqueLiftQ[conn, proj]", "Input",ExpressionUUID->"16181251-77c7-43ec-8908-d8e6ebae59c8"],

Cell["Visualize with ConnectionViewer:", "Text",ExpressionUUID->"be0de2a8-a79d-4a50-b4c5-3c84726c2050"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
conn = RandomConnection[total, proj];
ConnectionViewer[total, proj, conn]\
\>", "Input",ExpressionUUID->"17f74702-cad9-49d6-b775-83d9cb5eb812"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"9a65f32f-e27e-4297-aaf7-d4b8f9f060c2"
]
