Notebook[{
Cell["ReconstructBaseGraph", "Title",ExpressionUUID->"fbfec817-8ca1-42c9-85c9-942a5f12beb2"],

Cell["\<\
ReconstructBaseGraph[total, proj] reconstructs the base graph from a total \
space graph and projection.\
\>", "Text",ExpressionUUID->"17b9f20d-c7f2-4f17-aed0-21c9f4f0d613"],

Cell["\<\
ReconstructBaseGraph[total, proj, opts] passes options to Graph.\
\>", "Text",ExpressionUUID->"043be0f1-0acb-4263-97d6-c57211327f38"],

Cell["Details", "Section",ExpressionUUID->"98e1d0aa-5991-417e-b8cb-0e457ad9a924"],

Cell["\<\
The projection proj is an Association mapping total space vertices to base \
vertices.\
\>", "Text",ExpressionUUID->"a8c4511d-ee8e-426a-8601-c3e20a24cdb5"],

Cell["\<\
ReconstructBaseGraph extracts the base graph by projecting edges and removing \
duplicates and self-loops.\
\>", "Text",ExpressionUUID->"f0c698a3-b75c-4f1c-bc4d-96b4447fe740"],

Cell["\<\
The reconstructed base graph is isomorphic to the original base graph used to \
create the fibration.\
\>", "Text",ExpressionUUID->"5976bcca-5eb6-4e27-bf32-e98405bb3f21"],

Cell["Examples", "Section",ExpressionUUID->"7ccc54e9-edee-496a-8ab5-42c7ad9dc840"],

Cell["Needs[\"WolframInstitute`InfraGaugeTheory`\"]", "Input",ExpressionUUID->"3d47199d-67db-4aca-8816-c964d8925302"],

Cell["Reconstruct the base from a fibration over a cycle:", "Text",ExpressionUUID->"98f6f42c-0c19-4167-b8d2-88e18bffce8e"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
base = ReconstructBaseGraph[total, proj];
IsomorphicGraphQ[base, CycleGraph[5]]\
\>", "Input",ExpressionUUID->"c7276ff8-73d1-49a6-9e6b-8fc8ef41cde1"],

Cell["Reconstruct from a grid fibration:", "Text",ExpressionUUID->"f349ae54-85be-4240-9e50-68ce6aec2bfb"],

Cell["\<\
{total, proj} = RandomGraphFibration[GridGraph[{3, 3}], \"VerticalVertices\" \
-> 2];
base = ReconstructBaseGraph[total, proj];
{VertexCount[base], EdgeCount[base]}\
\>", "Input",ExpressionUUID->"bb590b60-fb64-437e-9a84-6e8df57f1470"],

Cell["Pass graph options:", "Text",ExpressionUUID->"5841afb4-b282-4d84-a934-8d78f39f6968"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
ReconstructBaseGraph[total, proj, GraphLayout -> \"CircularEmbedding\", \
VertexLabels -> Automatic]\
\>", "Input",ExpressionUUID->"480ca2c7-fadf-4072-b7e7-3bc1ccb6009e"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"9a65f32f-e27e-4297-aaf7-d4b8f9f060c2"
]
