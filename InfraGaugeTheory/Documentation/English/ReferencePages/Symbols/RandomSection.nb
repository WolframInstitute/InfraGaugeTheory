Notebook[{
Cell["RandomSection", "Title",ExpressionUUID->"c8754e68-97f4-4ad1-92a1-1074402624c3"],

Cell["\<\
RandomSection[total, proj] generates a random section of a fiber bundle.\
\>", "Text",ExpressionUUID->"1e0975c6-8673-4c2f-8c77-cc491a6e38c7"],

Cell["\<\
RandomSection[total, proj, domain] generates a section restricted to the \
given base vertices.\
\>", "Text",ExpressionUUID->"0ba85a38-deb8-4153-8c29-10cd86b74ed5"],

Cell["Details", "Section",ExpressionUUID->"bc150692-c429-4f3d-a492-3c11ee201502"],

Cell["\<\
A section assigns to each base vertex a fiber vertex projecting to it: a \
right inverse of proj.\
\>", "Text",ExpressionUUID->"0a8ff315-7f5d-47f7-ab90-f230aa084411"],

Cell["RandomSection picks uniformly at random from each fiber.", "Text",ExpressionUUID->"6a20a1bd-7b16-422f-b565-32d2bea5ee15"],

Cell["\<\
A random section is not necessarily smooth (adjacent base vertices may map to \
non-adjacent fiber vertices).\
\>", "Text",ExpressionUUID->"96dc86a5-b115-4604-bdf2-23934c3521c4"],

Cell["\<\
Use SmoothSectionQ to test smoothness. Use SmoothSection to extend a partial \
section smoothly.\
\>", "Text",ExpressionUUID->"dc7bbe85-b30e-4f52-9657-122ab584d9a0"],

Cell["Examples", "Section",ExpressionUUID->"487bbd5b-d168-42fe-8c91-4cafeb4ff460"],

Cell["Needs[\"WolframInstitute`InfraGaugeTheory`\"]", "Input",ExpressionUUID->"8d4b4c19-65f4-418a-b206-c67f6200c6c2"],

Cell["Random section over a cycle fibration:", "Text",ExpressionUUID->"728eec39-9e41-4a7a-86b6-713197beaae3"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
section = RandomSection[total, proj];
{Length[section], AllTrue[Normal[section], rule |-> proj[Last[rule]] === \
First[rule]]}\
\>", "Input",ExpressionUUID->"279c5c4d-2f54-4b58-8f4c-cf0305936c17"],

Cell["Partial section on a subset of base vertices:", "Text",ExpressionUUID->"53c9a862-8795-45e8-a816-f76fb8bc2a03"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
RandomSection[total, proj, {1, 2, 3}]\
\>", "Input",ExpressionUUID->"008d04ac-6872-4eca-ba43-be3baccf32e3"],

Cell["Test if a random section is smooth:", "Text",ExpressionUUID->"7e115034-acfe-47d4-89c2-72a6cdfec22e"],

Cell["\<\
{total, proj} = RandomGraphFibration[CycleGraph[5], \"VerticalVertices\" -> 3];
section = RandomSection[total, proj];
SmoothSectionQ[total, proj, section]\
\>", "Input",ExpressionUUID->"7bdf0402-eb48-485f-85f3-2879c77505f1"]
},
FrontEndVersion->"14.3 for Mac OS X ARM (64-bit) (July 8, 2025)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"9a65f32f-e27e-4297-aaf7-d4b8f9f060c2"
]
